# --- Data (large; fetched via data/download_data.py or regenerated by preprocessing/) ---
/data/*
!/data/README.md
!/data/download_data.py
# Tier-A: tiny AAL electrode-location CSVs are committed so region info / brain maps
# work with no download.
!/data/electrode_locations/
!/data/electrode_locations/**
ds004789-download/
dr-processed/
dr-temp/
dr-indexes/
logs/
.ieeg_data_root

# --- Generated results (regenerated by the notebooks; only docs/figures are tracked) ---
results/**/*.png
results/**/*.html
results/**/*.csv
results/**/*.npy
results/**/*.npz
results/**/cache/

# --- Model / HF caches ---
hf_cache/

# --- Large signal files (never commit) ---
*.edf
*.fif

# --- Python ---
__pycache__/
*.py[cod]
.ipynb_checkpoints/
.venv/
venv/
*.egg-info/

# --- Editors / OS ---
.idea/
.vscode/
.DS_Store
Thumbs.db
